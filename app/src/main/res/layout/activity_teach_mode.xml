<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="110dp">

            <!-- ── HEADER ──────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="52dp"
                android:paddingBottom="20dp">

                <!-- Back button -->
                <LinearLayout
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_back_btn"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="‹"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teach Mode"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap each tacton to feel the difference"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_subtle"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp" />

            <!-- ── ACTIVE INDICATOR CARD ────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_active_indicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stroke_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Pulsing ring + waveform viz -->
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="14dp">

                        <View
                            android:id="@+id/view_pulse_ring"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_pulse_ring"
                            android:alpha="0" />

                        <View
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_lra_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="◈"
                            android:textColor="@color/accent_primary"
                            android:textSize="16sp" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_active_tacton_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select a tacton below"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_active_tacton_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap any button to fire the LRA"
                            android:textColor="@color/text_tertiary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_active_tier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_urgency_badge"
                        android:text="—"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── TACTON BUTTONS ───────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:text="NOTIFICATION TYPES"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.16" />

            <!-- 1. pulse_burst -->
            <LinearLayout
                android:id="@+id/btn_pulse_burst"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_tacton_row_critical"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emergency / Critical"
                        android:textColor="#FF6B7A"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="pulse_burst"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-mono"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_emergency"
                    app:tint="@color/tier_critical" />

            </LinearLayout>

            <!-- 2. health_ramp -->
            <LinearLayout
                android:id="@+id/btn_health_ramp"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_tacton_row_health"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Health / Take Pills"
                        android:textColor="#6BFF9E"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="health_ramp"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-mono"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_health"
                    app:tint="@color/tier_health" />

            </LinearLayout>

            <!-- 3. slow_ramp -->
            <LinearLayout
                android:id="@+id/btn_slow_ramp"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_tacton_row_info"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bus or Metro Transit"
                        android:textColor="#FFD07B"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="slow_ramp"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-mono"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_transit"
                    app:tint="@color/tier_informational" />

            </LinearLayout>

            <!-- 4. nav_slide -->
            <LinearLayout
                android:id="@+id/btn_nav_slide"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_tacton_row_social"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Navigation / Turning Cues"
                        android:textColor="#7EB8FF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="nav_slide"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-mono"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_navigation"
                    app:tint="@color/tier_social" />

            </LinearLayout>

            <!-- 5. confirm_tap -->
            <LinearLayout
                android:id="@+id/btn_confirm_tap"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_tacton_row_system"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System / Button Pressed"
                        android:textColor="#C4B5FD"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="confirm_tap"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-mono"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_system"
                    app:tint="@color/accent_secondary" />

            </LinearLayout>

            <!-- 6. wait_hold -->
            <LinearLayout
                android:id="@+id/btn_wait_hold"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_tacton_row_system"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Processing / Status"
                        android:textColor="#C4B5FD"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="wait_hold"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-mono"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_processing"
                    app:tint="@color/accent_primary" />

            </LinearLayout>

            <!-- ── NEUROPHYSIOLOGY NOTE ──────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stroke_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HARDWARE NOTE"
                        android:textColor="@color/text_tertiary"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.16"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="All waveforms optimised for the Poco X7 Pro LRA. MIUI amplitude remapping means values use exaggerated contrast (60 vs 220) rather than linear scaling. A 15ms recovery gap is enforced after each cancel() call."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_nav_bar" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
