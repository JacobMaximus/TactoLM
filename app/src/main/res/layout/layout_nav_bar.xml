<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_gravity="bottom"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="20dp"
    android:background="@drawable/bg_nav_pill"
    android:baselineAligned="false"
    android:elevation="12dp"
    android:gravity="center"
    android:orientation="horizontal">

    <!-- Home Mode -->
    <LinearLayout
        android:id="@+id/nav_btn_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/nav_icon_home"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_home"
            android:contentDescription="Home" />

        <TextView
            android:id="@+id/nav_label_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Home"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Teach Mode -->
    <LinearLayout
        android:id="@+id/nav_btn_teach"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/nav_icon_teach"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_teach"
            android:contentDescription="Teach Mode" />

        <TextView
            android:id="@+id/nav_label_teach"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Teach"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Notification Feed -->
    <LinearLayout
        android:id="@+id/nav_btn_feed"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/nav_icon_feed"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_feed"
            android:contentDescription="Notification Feed" />

        <TextView
            android:id="@+id/nav_label_feed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Feed"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Vision -->
    <LinearLayout
        android:id="@+id/nav_btn_vision"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/nav_icon_vision"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_vision"
            android:contentDescription="Vision" />

        <TextView
            android:id="@+id/nav_label_vision"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Vision"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Door Bell -->
    <LinearLayout
        android:id="@+id/nav_btn_doorbell"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/nav_icon_doorbell"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_doorbell"
            android:contentDescription="Door Bell" />

        <TextView
            android:id="@+id/nav_label_doorbell"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Door Bell"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

</LinearLayout>
