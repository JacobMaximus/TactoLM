<?xml version="1.0" encoding="utf-8"?>
<!--
    item_tacto_card.xml
    Card layout for a single detected object.

    Inflated by TactoActivity and added to tacto_card_container.
    Initial alpha is 0 for the fade-in animation.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    android:alpha="0"
    android:background="@drawable/bg_card"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Object label — large, white, bold -->
        <TextView
            android:id="@+id/tacto_card_tv_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Object Label"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <!-- Category name — smaller, coloured -->
        <TextView
            android:id="@+id/tacto_card_tv_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORY"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#4ECDC4"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.06"
            android:layout_marginBottom="6dp" />

        <!-- Confidence badge — small, grey -->
        <TextView
            android:id="@+id/tacto_card_tv_confidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIGH"
            android:textSize="11sp"
            android:textColor="#888888"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.04"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/tacto_bg_confidence_badge" />

    </LinearLayout>

</LinearLayout>
