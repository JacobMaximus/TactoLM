<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════
         SCROLLABLE CONTENT
    ═══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ─────────────────────────────────────
                 HEADER BAR
            ───────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/header_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_deep"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="52dp"
                android:paddingBottom="16dp"
                android:gravity="center_vertical">

                <!-- App Icon placeholder (tactile glyph) -->
                <TextView
                    android:id="@+id/app_icon_glyph"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_glyph"
                    android:gravity="center"
                    android:text="◈"
                    android:textColor="@color/accent_primary"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <TextView
                        android:id="@+id/tv_app_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tv_app_tagline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_tagline"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:letterSpacing="0.08" />

                </LinearLayout>

                <!-- Status pill -->
                <LinearLayout
                    android:id="@+id/status_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_status_pill"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/bg_status_dot"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE"
                        android:textColor="@color/status_active"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.14" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider line below header -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_subtle"
                android:layout_marginHorizontal="20dp" />

            <!-- ─────────────────────────────────────
                 LATENCY STRIP — DUAL TRACK READOUT
            ───────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/latency_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <!-- Fast Track latency card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_fast_latency"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/stroke_subtle"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡ FAST TRACK"
                            android:textColor="@color/accent_primary"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16" />

                        <TextView
                            android:id="@+id/tv_fast_latency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— ms"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="on-device"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:layout_marginTop="1dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Gemini latency card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_gemini_latency"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/stroke_subtle"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦ GEMINI"
                            android:textColor="@color/accent_secondary"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.16" />

                        <TextView
                            android:id="@+id/tv_gemini_latency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— ms"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="smart track"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:layout_marginTop="1dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ─────────────────────────────────────
                 WAVEFORM VISUALIZATION CARD
            ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_waveform"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stroke_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="LRA OUTPUT"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.14" />

                        <TextView
                            android:id="@+id/tv_tacton_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="idle"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08" />

                    </LinearLayout>

                    <!-- Waveform bar visualizer (custom view placeholder using LinearLayout) -->
                    <com.tactolm.ui.WaveformView
                        android:id="@+id/waveform_view"
                        android:layout_width="match_parent"
                        android:layout_height="56dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ─────────────────────────────────────
                 CLASSIFICATION OUTPUT CARD
            ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stroke_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CLASSIFICATION OUTPUT"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.14" />

                        <!-- Track source badge -->
                        <TextView
                            android:id="@+id/tv_track_source"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_track_badge"
                            android:text="FAST"
                            android:textColor="@color/accent_primary"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.12"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:visibility="invisible" />

                    </LinearLayout>

                    <!-- Urgency tier row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="URGENCY"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.10" />

                        <TextView
                            android:id="@+id/tv_urgency_tier"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_urgency_badge"
                            android:text="—"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />

                    </LinearLayout>

                    <!-- Tacton row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="TACTON"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.10" />

                        <TextView
                            android:id="@+id/tv_tacton_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-mono"
                            android:letterSpacing="0.04" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/stroke_subtle"
                        android:layout_marginBottom="10dp" />

                    <!-- Payload label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAYLOAD"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:layout_marginBottom="6dp" />

                    <!-- Payload text -->
                    <TextView
                        android:id="@+id/tv_payload"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/output_idle"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif"
                        android:lineSpacingMultiplier="1.4"
                        android:background="@drawable/bg_payload_box"
                        android:padding="12dp" />

                    <!-- Rationale (Gemini, shown subtly) -->
                    <TextView
                        android:id="@+id/tv_rationale"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text=""
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>



            <!-- ─────────────────────────────────────
                 BENGALURU DEMO SCENARIOS
            ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BENGALURU SCENARIOS"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14"
                    android:layout_marginBottom="10dp" />

                <!-- Scenario buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- BBMP Health -->
                    <LinearLayout
                        android:id="@+id/btn_scenario_bbmp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_scenario_health"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏥"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BBMP\nHealth"
                            android:textColor="@color/tier_health"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingMultiplier="1.2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="health_ramp"
                            android:textColor="@color/text_tertiary"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-mono"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- Emergency -->
                    <LinearLayout
                        android:id="@+id/btn_scenario_emergency"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_scenario_critical"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginHorizontal="3dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚨"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emergency"
                            android:textColor="@color/tier_critical"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingMultiplier="1.2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="pulse_burst"
                            android:textColor="@color/text_tertiary"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-mono"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- Social -->
                    <LinearLayout
                        android:id="@+id/btn_scenario_social"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_scenario_social"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Social"
                            android:textColor="@color/tier_social"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingMultiplier="1.2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="grit_texture"
                            android:textColor="@color/text_tertiary"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-mono"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ─────────────────────────────────────
                 TEACH MODE SHORTCUT
            ───────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/btn_teach_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_teach_mode"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teach Mode"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play all 6 tactons in sequence"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/accent_primary"
                    android:textSize="24sp" />

            </LinearLayout>

            <!-- ─────────────────────────────────────
                 NOTIFICATIONS FEED SHORTCUT
            ───────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/btn_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_teach_mode"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifications Feed"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View recent alerts and haptic history"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/accent_secondary"
                    android:textSize="24sp" />

            </LinearLayout>

            <!-- ─────────────────────────────────────
                 FOOTER
            ───────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="@string/footer_note"
                android:textColor="@color/text_disabled"
                android:textSize="10sp"
                android:letterSpacing="0.06" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>