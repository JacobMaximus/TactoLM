<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep black base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#060D07" />
        </shape>
    </item>
    <!-- Green radial glow at top-center, like the reference -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="75%p"
                android:centerX="0.5"
                android:centerY="0.1"
                android:startColor="#22402A"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
