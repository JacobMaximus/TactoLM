<?xml version="1.0" encoding="utf-8"?>
<!--
    TactoLM launcher icon foreground.
    Stylised "T" with:
      - Rounded top bar
      - Vertical stem
      - Two Braille dots on the left
      - Three wifi-arc waves on the right
    All drawn in the brand green #7ED321 on a 108×108 adaptive canvas.
    The safe zone is the inner 72×72 (18dp inset on every side).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Top bar of the T (rounded rectangle) ── -->
    <path
        android:fillColor="#7ED321"
        android:pathData="
          M32,26
          Q32,20 38,20
          L70,20
          Q76,20 76,26
          L76,36
          Q76,42 70,42
          L38,42
          Q32,42 32,36
          Z" />

    <!-- ── Vertical stem of the T ── -->
    <path
        android:fillColor="#7ED321"
        android:pathData="
          M48,42
          L60,42
          L60,88
          Q60,92 54,92
          Q48,92 48,88
          Z" />

    <!-- ── Braille dots (two circles, left of the stem) ── -->
    <path
        android:fillColor="#7ED321"
        android:pathData="M36,52 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0" />
    <path
        android:fillColor="#7ED321"
        android:pathData="M36,66 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0" />

    <!-- ── WiFi arc 1 (smallest, closest to stem) ── -->
    <path
        android:strokeColor="#7ED321"
        android:strokeWidth="3.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M64,62 Q70,60 70,54 Q70,48 64,46" />

    <!-- ── WiFi arc 2 (medium) ── -->
    <path
        android:strokeColor="#7ED321"
        android:strokeWidth="3.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M64,70 Q78,66 78,54 Q78,42 64,38" />

    <!-- ── WiFi arc 3 (largest) ── -->
    <path
        android:strokeColor="#7ED321"
        android:strokeWidth="3.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M64,78 Q86,72 86,54 Q86,36 64,30" />

</vector>