<?xml version="1.0" encoding="utf-8"?>
<!-- Neon-green focus ring drawn as FOREGROUND overlay.
     Uses no fill so the original button background shows through. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="12dp" />
    <stroke
        android:width="3dp"
        android:color="#39D353" />
</shape>
