<?xml version="1.0" encoding="utf-8"?>
<!--
    Antigravity symbol — an upward-facing diamond (rhombus) with a
    horizontal mid-line, suggesting levitation / anti-gravity.
    Designed as a clean, geometric monochrome mark.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Outer diamond outline -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:fillColor="#00000000"
        android:pathData="M12,2 L22,12 L12,22 L2,12 Z" />

    <!-- Horizontal mid-line (the "gravity horizon") -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:fillColor="#00000000"
        android:strokeLineCap="square"
        android:pathData="M4.4,12 L19.6,12" />

    <!-- Small filled top diamond (the "rising" element) -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,4.5 L15,9 L12,11.5 L9,9 Z" />

</vector>
