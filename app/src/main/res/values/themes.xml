<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme — forced dark, no action bar -->
    <style name="Base.Theme.TactoLM" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="android:windowBackground">@drawable/bg_screen</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.TactoLM" parent="Base.Theme.TactoLM" />

    <!-- Card style -->
    <style name="TactoLM.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/stroke_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>

    <!-- Input field style -->
    <style name="TactoLM.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/stroke_medium</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_tertiary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="materialThemeOverlay">@style/TactoLM.TextInput.ThemeOverlay</item>
    </style>

    <style name="TactoLM.TextInput.ThemeOverlay">
        <item name="colorPrimary">@color/accent_primary</item>
    </style>

    <!-- Primary button -->
    <style name="TactoLM.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Outline button -->
    <style name="TactoLM.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/stroke_medium</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Chip / badge label style -->
    <style name="TactoLM.Label" parent="Widget.Material3.Chip.Assist">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

</resources>